<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>New Arrivals - Cougar Clothing Store</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    <div class="announcement-bar">
        FLAT 50% OFF ON ALL PRODUCTS-<a href="/sale">SHOP NOW</a>
    </div>
    <header class="header" id="main-header">
        <nav class="nav-left" id="nav-menu">
            <a href="/sale" class="sale-link">Sale</a>
            <a href="/men">Men</a>
            <a href="/women">Women</a>
            <a href="/kids">Kids</a>
            <a href="/new-arrivals">New Arrivals</a>
        </nav>
        <div class="logo">
            <a href="/">COUGAR</a>
        </div>
        <button class="hamburger" id="hamburger" aria-label="Toggle navigation" aria-expanded="false">&#9776;</button>
    </header>

    <section class="page-content">
        <h1>New Arrivals</h1>
        <p>Be the first to wear the latest trends! Check out our freshest drops — new styles added every week across all categories.</p>

        <div class="product-grid">
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1521572163474-6864f9cf17ab?w=400&h=500&fit=crop&q=80" alt="New Arrival T-Shirt">
                <h3>Oversized Graphic Tee</h3>
                <p class="price">Rs. 2,000</p>
            </div>
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1539008835657-9e8e9680c956?w=400&h=500&fit=crop&q=80" alt="New Arrival Jacket">
                <h3>Streetwear Bomber Jacket</h3>
                <p class="price">Rs. 7,500</p>
            </div>
            <div class="product-card">
                <img src="https://images.unsplash.com/photo-1552374196-1ab2a1c593e8?w=400&h=500&fit=crop&q=80" alt="New Arrival Outfit">
                <h3>Premium Linen Shirt</h3>
                <p class="price">Rs. 4,200</p>
            </div>
        </div>
    </section>

    <footer class="footer">
        <div class="footer-content">
            <div class="footer-column">
              <h4>Customer Support</h4>
             <ul>
                <li><a href="#">Contact Us</a></li>
                <li><a href="#">FAQs</a></li>
                <li><a href="#">Shipping Policy</a></li>
                <li><a href="#">Returns & Exchanges</a></li>
             </ul>
            </div>
             <div class="footer-column">
                <h4>About Cougar</h4>
                <ul>
                    <li><a href="#">FAQ'S</a></li>
                    <li><a href="#">Log in/Sign Up</a></li>
                    <li><a href="#">Shipping &amp; Deliveries</a></li>
                    <li><a href="#">Order Cancellation</a></li>
                    <li><a href="#">Blogs &amp; News</a></li>
                </ul>
            </div>
             <div class="footer-column">
                <h4>Get To Know Us</h4>
                <ul>
                    <li><a href="#">Contact Us</a></li>
                    <li><a href="#">Feedback / Complaint</a></li>
                    <li><a href="#">Track Your Order</a></li>
                    <li><a href="#">Privacy Policy</a></li>
                    <li><a href="#">Return &amp; Exchange Policy</a></li>
                    <li><a href="#">Terms And Condition</a></li>
                </ul>
            </div>
                <div class="newsletter">
                    <h4>Subscribe to our Newsletter</h4>
                    <p>Get updates on sales, new arrivals, and exclusive offers.by entering the correct details, you may get our latest updates on your entered email, don't forget to enter your credentials here.</p>
                    <form class="newsletter-form">
                        <input type="email" placeholder="Enter your email" required>
                        <button type="submit">Subscribe</button>
                    </form>
                </div>

        </div>
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
